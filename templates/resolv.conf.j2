# resolv.conf by ansible
#     DO NOT EDIT THIS FILE BY HAND -- YOUR CHANGES WILL BE OVERWRITTEN
{% if system_network_local_dns %}
nameserver 127.0.0.1
nameserver {{ ansible_facts['default_ipv4']['address'] }}
{% endif %}
{% if system_network_dns %}
{% for ns in system_network_dns|sort if ('127.0.0.1' not in ns) and (ansible_facts['default_ipv4']['address']|default('') not in ns) %}
nameserver {{ ns }}
{% endfor %}
{% else %}
nameserver 1.1.1.1
nameserver 2606:4700:4700::1111
{% endif %}
{% if system_network_search_dns and (ansible_facts['dns']['search'] | default([])) | length > 0 %}
search {{ ansible_facts['dns']['search'] | join(' ') }}
{% endif %}
options timeout:5 attempts:3
